<!DOCTYPE html>
<html lang="ca">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Creador d'animacions</title>
    <!-- Incloure Tailwind CSS des del CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Incloure JSZip per a la generació del fitxer ZIP (per desar seqüència) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <!-- Incloure GIF.js per a la generació de GIF animats -->
     <script src="gifshot.min.js"></script>
    <style>
        /* Configuració del tema Tailwind i la font Inter */
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                }
            }
        }
        /* Estils personalitzats per al backdrop del diàleg */
        dialog::backdrop {
            background-color: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(3px);
        }

        /* Estil per als botons de càrrega */
        .upload-button {
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .upload-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2); 
        }

        /* Estil per l'àrea d'animació */
        #animationArea {
            min-height: 250px;
            max-width: 100%;
            width: 100%; 
            transition: background-color 0.5s ease;
        }

        #animationImage {
            max-width: 100%;
            height: auto;
            max-height: 400px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            object-fit: contain;
        }
        
        /* Estil per al text del nom del fitxer */
        #imageFileName {
            background-color: rgba(255, 255, 255, 0.8); 
            padding: 4px 8px;
            border-radius: 6px;
        }

        /* Fix per evitar el salt visual del botó Play/Stop */
        #playStopToggle {
            min-width: 190px; 
        }

        /* Estils per a la llista Drag & Drop */
        .list-item {
            cursor: grab;
            padding: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: background-color 0.15s, opacity 0.3s, border-left 0.3s;
            border-left: 5px solid transparent;
        }
        .list-item:hover {
            background-color: #f3f4f6;
        }
        
        /* Estil per a la imatge seleccionada actualment */
        .list-item.is-current {
            background-color: #e0e7ff;
            border-left: 5px solid #4f46e5;
            font-weight: 600;
        }
        .list-item.is-current .frame-name {
            color: #1e3a8a;
        }

        .list-item.dragging {
            opacity: 0.4;
        }
        .list-item.disabled {
            opacity: 0.5;
            text-decoration: line-through;
            cursor: default;
        }
        .list-item.disabled:hover {
             background-color: transparent; 
        }
        .list-item.disabled .drag-handle {
            cursor: default; 
        }
        .list-item .drag-handle {
            cursor: grab;
        }
        #listColumn {
            overflow-y: auto;
            max-height: 600px; 
        }
        #imageList {
            min-height: 450px;
        }
        
        /* Estil per a la miniatura */
        .thumbnail {
            width: 48px;
            height: 48px;
            object-fit: contain;
            border-radius: 4px;
            border: 1px solid #e5e7eb;
            margin-right: 8px;
        }

        /* Estil per al spinner de càrrega */
        .spinner {
            border: 4px solid rgba(0, 0, 0, 0.1);
            border-left-color: #3b82f6;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
            margin-right: 8px;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="bg-gray-50 flex flex-col justify-center items-center min-h-screen font-sans p-4">

    <!-- Contingut principal -->
    <div class="p-6 bg-white rounded-xl shadow-2xl max-w-6xl w-full text-center">
        <h1 class="text-3xl font-extrabold text-indigo-700 mb-2">Creador d'animacions</h1>
        <p class="text-gray-600 mb-6">Selecciona una seqüència d'imatges per veure-les, reordenar-les i desar-les.</p>
        
        <!-- CONTENIDOR DE BOTONS DE CÀRREGA -->
        <div class="flex flex-col sm:flex-row justify-center space-y-4 sm:space-y-0 sm:space-x-4 mx-auto mb-8">
            <!-- Botó Seleccionar Imatges -->
            <button id="openDialogButton" 
                    class="upload-button bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold shadow-lg hover:bg-indigo-700 focus:outline-none focus:ring-4 focus:ring-indigo-500 focus:ring-opacity-50 uppercase">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M5.5 13a.5.5 0 01.5-.5h2a.5.5 0 010 1H6a.5.5 0 01-.5-.5z" />
                    <path fill-rule="evenodd" d="M15 13V5a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2zM4.5 13V5c0-.36.2-.67.48-.79l.06-.02h9.92c.28.12.48.43.48.79v8c0 .36-.2.67-.48.79l-.06-.02H4.5z" clip-rule="evenodd" />
                </svg>
                SELECCIONAR IMATGES
            </button>

            <!-- Botó Importar Vídeo -->
            <button id="openVideoDialogButton" 
                    class="upload-button bg-blue-500 text-white px-6 py-3 rounded-xl font-semibold shadow-lg hover:bg-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-500 focus:ring-opacity-50 uppercase">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm.5 13a.5.5 0 010-1h11a.5.5 0 010 1h-11zM10 7a1 1 0 00-1 1v4a1 1 0 001 1h4a1 1 0 001-1V8a1 1 0 00-1-1h-4z"/>
                    <path d="M10 9.5a.5.5 0 01.5-.5h3a.5.5 0 01.5.5v3a.5.5 0 01-.5.5h-3a.5.5 0 01-.5-.5v-3z"/>
                </svg>
                IMPORTAR VÍDEO
            </button>
        </div>


        <!-- Grid Container per al Visor i la Llista -->
        <div id="mainGrid" class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6 hidden">
            
            <!-- COLUMNA ESQUERRA: Visor i Controls de Reproducció -->
            <div id="viewerColumn" class="flex flex-col items-center">
                
                <!-- Àrea de visualització de l'animació -->
                <div id="animationArea" class="flex flex-col items-center justify-center p-4 border border-gray-200 bg-gray-100 rounded-xl w-full">
                    <p id="initialMessage" class="text-gray-500 italic">Aquí es mostrarà l'animació.</p>
                    <img id="animationImage" class="hidden" alt="Imatge d'Animació">
                    <p id="imageFileName" class="hidden mt-2 text-sm font-semibold text-gray-700 truncate w-full px-2 text-center">Nom del Fitxer: </p>
                </div>

                <!-- Control de Reproducció, Manuals i Botons de Guardar -->
                <div id="playbackControls" class="mt-4 flex flex-wrap justify-center items-center space-x-2 space-y-2 sm:space-y-0 w-full">
                    
                    <!-- Botó Anterior -->
                    <button id="prevButton" onclick="manualNavigate(-1)" disabled
                            class="p-2 text-indigo-600 bg-indigo-100 rounded-full hover:bg-indigo-200 transition duration-150 shadow-md opacity-50 cursor-not-allowed">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                    </button>
                    
                    <!-- Botó Toggle (Stop/Play) -->
                    <button id="playStopToggle" 
                            class="px-5 py-2 font-medium text-white bg-red-600 rounded-xl shadow-lg hover:bg-red-700 transition duration-150"
                            onclick="toggleAnimation()">
                        🔴 Aturar Animació
                    </button>

                    <!-- Botó Següent -->
                    <button id="nextButton" onclick="manualNavigate(1)" disabled
                            class="p-2 text-indigo-600 bg-indigo-100 rounded-full hover:bg-indigo-200 transition duration-150 shadow-md opacity-50 cursor-not-allowed">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                    </button>

                    <!-- Grup de Botons de Desa -->
                    <div class="flex space-x-2 ml-4">
                        <button id="saveSequenceButton" onclick="showSaveOptions('sequence')"
                                class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition duration-150">
                            💾 Guardar Seqüència
                        </button>
                        <button id="saveGifButton" onclick="showSaveOptions('gif')"
                                class="px-4 py-2 text-sm font-medium text-white bg-purple-600 rounded-xl hover:bg-purple-700 transition duration-150">
                            🖼️ Guardar GIF Animat
                        </button>
                    </div>
                </div>

                <!-- Àrea de Guardar -->
                <div id="saveInputArea" class="mt-4 p-4 bg-yellow-100 rounded-xl w-full max-w-lg hidden">
                    <label for="sequenceNameInput" class="block text-sm font-medium text-gray-800 mb-2 text-left">
                        Nom base per a la descàrrega:
                    </label>
                    <input type="text" id="sequenceNameInput" placeholder="Ex: Projecte_Animat"
                           class="w-full px-3 py-2 border border-yellow-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-500 mb-3 text-sm">

                    <!-- Opcions de DESA COM A SEQÜÈNCIA -->
                    <div id="sequenceSaveOptions" class="space-y-3 hidden">
                        <h4 class="text-md font-bold text-gray-800 mb-2 text-left">Opcions de Seqüència d'Imatges</h4>
                        <div class="flex items-center">
                            <input id="downloadAsZip" type="checkbox"
                                   class="form-checkbox h-4 w-4 text-yellow-600 transition duration-150 ease-in-out border-gray-300 rounded focus:ring-yellow-500">
                            <label for="downloadAsZip" class="ml-2 block text-sm text-gray-800 font-semibold">
                                Descarregar tota la seqüència en un sol fitxer ZIP
                            </label>
                        </div>
                        <button onclick="saveSequenceFiles()"
                                class="w-full px-4 py-2 text-sm font-medium text-white bg-yellow-600 rounded-xl hover:bg-yellow-700 transition duration-150"
                                id="downloadSequenceButton">
                            Confirmar i Descarregar Imatges
                        </button>
                        <p id="downloadNote" class="mt-2 text-xs text-yellow-800 text-left">
                            **Nota important:** Si descarregueu fitxers individuals, pot ser que se us demani permís per a la descàrrega de múltiples fitxers.
                        </p>
                    </div>

                    <!-- Opcions de DESA COM A GIF -->
                    <div id="gifSaveOptions" class="space-y-3 hidden">
                        <h4 class="text-md font-bold text-gray-800 mb-2 text-left">Opcions de GIF Animat</h4>
                        <div class="flex items-center">
                            <input id="gifLoopCheckbox" type="checkbox" checked
                                   class="form-checkbox h-4 w-4 text-purple-600 transition duration-150 ease-in-out border-gray-300 rounded focus:ring-purple-500">
                            <label for="gifLoopCheckbox" class="ml-2 block text-sm text-gray-800 font-semibold">
                                Bucle infinit (Loop)
                            </label>
                        </div>
                        <button onclick="saveAsGif()"
                                class="w-full px-4 py-2 text-sm font-medium text-white bg-purple-600 rounded-xl hover:bg-purple-700 transition duration-150"
                                id="generateGifButton">
                            Generar i Descarregar GIF
                        </button>
                        <p class="mt-2 text-xs text-yellow-800 text-left">
                            **Nota:** La generació de GIF es fa al teu navegador i pot trigar segons la mida dels frames.
                        </p>
                    </div>
                    
                    <button onclick="hideSaveInput()"
                            class="mt-4 w-full px-4 py-2 text-xs font-medium text-yellow-800 bg-yellow-200 rounded-xl hover:bg-yellow-300 transition duration-150">
                        Cancel·lar
                    </button>
                </div>


                <!-- Control de velocitat i Color -->
                <div id="speedControls" class="mt-4 p-4 bg-gray-100 rounded-xl w-full max-w-sm">
                    <label for="speedSlider" class="block text-sm font-medium text-gray-700 mb-2 flex justify-between items-center">
                        Temps d'espera (ms): 
                        <span id="speedValue" class="font-bold text-indigo-600">500</span>
                    </label>
                    <input type="range" id="speedSlider" min="0" max="1000" value="500" step="50" class="w-full h-2 bg-indigo-300 rounded-lg appearance-none cursor-pointer range-lg"
                           style="background-color: #a5b4fc;">

                    <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-300">
                        <label for="bgColorPicker" class="text-sm font-medium text-gray-700">
                            Color de Fons:
                        </label>
                        <input type="color" id="bgColorPicker" value="#f3f4f6"
                               class="h-8 w-12 rounded-lg border-none cursor-pointer p-0 overflow-hidden"
                               style="height: 32px; width: 48px;">
                    </div>
                </div>

            </div>

            <!-- COLUMNA DRETA: Llista d'Ordre -->
            <div id="listColumn" class="md:h-full">
                <div id="imageOrderSection">
                    <h2 class="text-xl font-bold text-gray-800 mb-3 text-left flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-indigo-500" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M12.586 4.586a2 2 0 112.828 2.828l-3.182 3.182a2 2 0 01-2.828 0 1 1 0 00-1.414 1.414 4 4 0 005.656 0l3.182-3.182a4 4 0 000-5.656 1 1 0 00-1.414 1.414z" clip-rule="evenodd" />
                            <path fill-rule="evenodd" d="M7.414 15.414a2 2 0 11-2.828-2.828l3.182-3.182a2 2 0 012.828 0 1 1 0 101.414-1.414 4 4 0 00-5.656 0l-3.182 3.182a4 4 0 005.656 5.656 1 1 0 001.414-1.414z" clip-rule="evenodd" />
                        </svg>
                        Ordre de la Seqüència
                    </h2>
                    
                    <!-- Controls de Selecció Massiva -->
                    <div class="flex space-x-2 mb-3">
                        <button onclick="toggleAllFrames(true)"
                                class="flex-1 px-3 py-1 text-xs font-semibold text-white bg-green-500 rounded-lg hover:bg-green-600 transition duration-150 disabled:opacity-50"
                                id="selectAllButton" disabled>
                            Seleccionar Totes
                        </button>
                        <button onclick="toggleAllFrames(false)"
                                class="flex-1 px-3 py-1 text-xs font-semibold text-gray-700 bg-gray-200 rounded-lg hover:bg-gray-300 transition duration-150 disabled:opacity-50"
                                id="deselectAllButton" disabled>
                            Deseleccionar Totes
                        </button>
                    </div>

                    <ul id="imageList" class="bg-white border border-gray-300 rounded-lg divide-y divide-gray-200 text-left shadow-md">
                        <li class="p-4 text-gray-500 italic">Carrega les imatges per veure la llista.</li>
                    </ul>
                </div>
            </div>

        </div>

    </div>
    
    <p class="mt-8 text-xs text-gray-400">
        Un desenvolupament de Xavier Ribes per al GameLab de la UAB
    </p>

    <!-- Diàleg 1: Imatges -->
    <dialog id="uploadDialog" 
            class="p-6 md:p-8 bg-white rounded-2xl shadow-2xl max-w-sm w-full transition-all duration-300">
        
        <div class="flex flex-col gap-6">
            <h3 class="text-2xl font-extrabold text-gray-900 border-b pb-3">
                Seleccionar Seqüència d'Imatges
            </h3>
            
            <form id="uploadForm" onsubmit="handleUpload(event)" class="space-y-4">
                
                <div>
                    <label for="fileInput" class="block text-sm font-medium text-gray-700 mb-2">
                        Selecciona múltiples imatges:
                    </label>
                    <input type="file" id="fileInput" name="file" required multiple accept="image/*"
                           class="w-full text-sm text-gray-500
                                  file:mr-4 file:py-2 file:px-4
                                  file:rounded-xl file:border-0
                                  file:text-sm file:font-semibold
                                  file:bg-indigo-50 file:text-indigo-700
                                  hover:file:bg-indigo-100" />
                    <p class="mt-1 text-xs text-gray-500">Formats acceptats: JPG, PNG, GIF.</p>
                </div>

                <div id="messageBox" class="p-3 rounded-lg text-sm hidden"></div>
                
                <div class="flex justify-end gap-3 pt-4 border-t">
                    <button id="closeDialogButton" type="button" 
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-200 rounded-xl hover:bg-gray-300 transition duration-150">
                        Cancel·lar
                    </button>
                    <button type="submit" 
                            class="px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-xl hover:bg-green-700 transition duration-150">
                        Carregar i Animar
                    </button>
                </div>
            </form>
        </div>
    </dialog>
    
    <!-- Diàleg 2: Vídeo -->
    <dialog id="videoDialog" 
            class="p-6 md:p-8 bg-white rounded-2xl shadow-2xl max-w-sm w-full transition-all duration-300">
        
        <div class="flex flex-col gap-6">
            <h3 class="text-2xl font-extrabold text-gray-900 border-b pb-3 text-blue-600">
                Extreure Imatges d'un Vídeo
            </h3>
            
            <form id="videoUploadForm" onsubmit="handleVideoUpload(event)" class="space-y-4">
                
                <div>
                    <label for="videoInput" class="block text-sm font-medium text-gray-700 mb-2">
                        Selecciona un fitxer de vídeo:
                    </label>
                    <input type="file" id="videoInput" name="video" required accept="video/*"
                           class="w-full text-sm text-gray-500
                                  file:mr-4 file:py-2 file:px-4
                                  file:rounded-xl file:border-0
                                  file:text-sm file:font-semibold
                                  file:bg-blue-50 file:text-blue-700
                                  hover:file:bg-blue-100" />
                    <p class="mt-1 text-xs text-gray-500">Formats: MP4, WebM, MOV, etc.</p>
                </div>
                
                <div class="mt-4">
                    <label for="frameRateInput" class="block text-sm font-medium text-gray-700 mb-2">
                        Frames per Segon (FPS):
                    </label>
                    <input type="number" id="frameRateInput" value="10" min="1" max="30" step="1" required
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm"/>
                    <p class="mt-1 text-xs text-gray-500">FPS més baix = menys imatges.</p>
                </div>

                <!-- Controls de Trim -->
                <div class="mt-4 p-3 border border-blue-200 rounded-lg bg-blue-50">
                    <p class="text-sm font-semibold text-blue-700 mb-2">Trim: Selecciona un Fragment</p>
                    <div class="grid grid-cols-2 gap-3">
                        <div class="flex flex-col">
                            <div class="min-h-[2.5rem]">
                                <label for="trimStartInput" class="block text-xs font-medium text-gray-700 mb-1">
                                    Inici (segons):
                                </label>
                            </div>
                            <input type="number" id="trimStartInput" value="0" min="0" step="0.1" 
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm"/>
                        </div>
                        <div class="flex flex-col">
                            <div class="min-h-[2.5rem]">
                                <label for="trimEndInput" class="block text-xs font-medium text-gray-700 mb-1">
                                    Final (0=tot):
                                </label>
                            </div>
                            <input type="number" id="trimEndInput" value="0" min="0" step="0.1" 
                                class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm"/>
                            <p id="videoDurationHint" class="mt-1 text-xs text-gray-500 italic hidden">Durada: 0s</p>
                        </div>
                    </div>
                </div>

                <div id="videoMessageBoxContainer" class="min-h-12">
                     <div id="videoMessageBox" class="p-3 rounded-lg text-sm hidden"></div>
                </div>
                
                <div class="flex justify-end gap-3 pt-4 border-t">
                    <button id="closeVideoDialogButton" type="button" 
                            class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-200 rounded-xl hover:bg-gray-300 transition duration-150">
                        Cancel·lar
                    </button>
                    <button type="submit" id="processVideoButton"
                            class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-xl hover:bg-blue-700 transition duration-150">
                        Processar Vídeo
                    </button>
                </div>
                <div id="loadingSpinner" class="flex items-center justify-center gap-2 text-blue-600 hidden">
                    <div class="spinner"></div>
                    <span id="spinnerMessage">Processant...</span>
                </div>
            </form>
        </div>
    </dialog>


    <script>
      

        // Variables globals
        let animationData = [];
        let animationInterval;
        let imageIndex = 0;
        let animationSpeed = 500;
        let dragSrcEl = null;
        
        // Referències als elements del DOM
        const openButton = document.getElementById('openDialogButton');
        const uploadDialog = document.getElementById('uploadDialog');
        const messageBox = document.getElementById('messageBox');
        const fileInput = document.getElementById('fileInput');
        const animationImage = document.getElementById('animationImage');
        const initialMessage = document.getElementById('initialMessage');
        const imageFileName = document.getElementById('imageFileName');
        const speedSlider = document.getElementById('speedSlider');
        const speedValue = document.getElementById('speedValue');
        const imageList = document.getElementById('imageList');
        const bgColorPicker = document.getElementById('bgColorPicker');
        const animationArea = document.getElementById('animationArea');
        const mainGrid = document.getElementById('mainGrid');
        const playStopToggle = document.getElementById('playStopToggle');
        const prevButton = document.getElementById('prevButton');
        const nextButton = document.getElementById('nextButton');
        const saveInputArea = document.getElementById('saveInputArea');
        const sequenceNameInput = document.getElementById('sequenceNameInput');
        const sequenceSaveOptions = document.getElementById('sequenceSaveOptions');
        const downloadAsZipCheckbox = document.getElementById('downloadAsZip');
        const downloadSequenceButton = document.getElementById('downloadSequenceButton');
        const downloadNote = document.getElementById('downloadNote');
        const saveGifButton = document.getElementById('saveGifButton');
        const gifSaveOptions = document.getElementById('gifSaveOptions');
        const gifLoopCheckbox = document.getElementById('gifLoopCheckbox');
        const generateGifButton = document.getElementById('generateGifButton');
        const openVideoButton = document.getElementById('openVideoDialogButton');
        const videoDialog = document.getElementById('videoDialog');
        const closeVideoDialogButton = document.getElementById('closeVideoDialogButton');
        const videoMessageBox = document.getElementById('videoMessageBox');
        const videoInput = document.getElementById('videoInput');
        const frameRateInput = document.getElementById('frameRateInput');
        const processVideoButton = document.getElementById('processVideoButton');
        const loadingSpinner = document.getElementById('loadingSpinner');
        const spinnerMessage = document.getElementById('spinnerMessage');
        const trimStartInput = document.getElementById('trimStartInput');
        const trimEndInput = document.getElementById('trimEndInput');
        const videoDurationHint = document.getElementById('videoDurationHint');
        const selectAllButton = document.getElementById('selectAllButton');
        const deselectAllButton = document.getElementById('deselectAllButton');
        
        let videoDuration = 0;

        // Funció per mostrar missatges
        function showMessage(text, isError = false, targetBox = messageBox) {
            targetBox.textContent = text;
            targetBox.classList.remove('hidden', 'bg-red-100', 'text-red-800', 'bg-blue-100', 'text-blue-800', 'bg-yellow-100', 'text-yellow-800');
            if (isError) {
                targetBox.classList.add('bg-red-100', 'text-red-800');
            } else if (targetBox === videoMessageBox) {
                targetBox.classList.add('bg-yellow-100', 'text-yellow-800');
            } else {
                targetBox.classList.add('bg-blue-100', 'text-blue-800');
            }
            if (!isError && targetBox !== videoMessageBox) {
                setTimeout(() => targetBox.classList.add('hidden'), 5000);
            }
        }

        // Gestió dels Diàlegs
        openButton.addEventListener('click', () => {
            uploadDialog.showModal();
            messageBox.classList.add('hidden');
        });

        document.getElementById('closeDialogButton').addEventListener('click', () => {
            uploadDialog.close();
        });
        
        openVideoButton.addEventListener('click', () => {
            videoDialog.showModal();
            videoMessageBox.classList.add('hidden');
            videoDuration = 0;
            videoDurationHint.classList.add('hidden');
        });

        closeVideoDialogButton.addEventListener('click', () => {
            videoDialog.close();
        });
        
        // Listener per carregar metadades del vídeo
        videoInput.addEventListener('change', () => {
            const file = videoInput.files[0];
            if (!file) return;
            const videoElement = document.createElement('video');
            videoElement.preload = 'metadata';
            videoElement.muted = true;
            const videoURL = URL.createObjectURL(file);
            videoElement.src = videoURL;

            videoElement.onloadedmetadata = () => {
                videoDuration = videoElement.duration;
                videoDurationHint.textContent = `Durada total: ${videoDuration.toFixed(2)} segons.`;
                videoDurationHint.classList.remove('hidden');
                trimEndInput.value = videoDuration.toFixed(2);
                URL.revokeObjectURL(videoURL);
            };

            videoElement.onerror = () => {
                videoDurationHint.textContent = 'Error llegint el vídeo.';
                videoDurationHint.classList.remove('hidden');
                videoDuration = 0;
                URL.revokeObjectURL(videoURL);
            }
        });

        // Funcions de control d'estat
        function updateManualControlState(canNavigate) {
            const controls = [prevButton, nextButton];
            controls.forEach(button => {
                button.disabled = !canNavigate;
                if (canNavigate) {
                    button.classList.remove('opacity-50', 'cursor-not-allowed');
                } else {
                    button.classList.add('opacity-50', 'cursor-not-allowed');
                }
            });
        }
        
        function updateMassSelectButtons() {
            const hasFrames = animationData.length > 0;
            selectAllButton.disabled = !hasFrames;
            deselectAllButton.disabled = !hasFrames;
        }

        function setProcessingState(isProcessing, message = "Processant...") {
            if (isProcessing) {
                loadingSpinner.classList.remove('hidden');
                spinnerMessage.textContent = message;
                processVideoButton.disabled = true;
                processVideoButton.classList.add('opacity-50', 'cursor-not-allowed');
                closeVideoDialogButton.disabled = false;
                videoInput.disabled = true;
                frameRateInput.disabled = true;
                trimStartInput.disabled = true;
                trimEndInput.disabled = true;
                videoMessageBox.classList.remove('hidden');
            } else {
                loadingSpinner.classList.add('hidden');
                processVideoButton.disabled = false;
                processVideoButton.classList.remove('opacity-50', 'cursor-not-allowed');
                closeVideoDialogButton.disabled = false;
                videoInput.disabled = false;
                frameRateInput.disabled = false;
                trimStartInput.disabled = false;
                trimEndInput.disabled = false;
            }
        }

        // Funcions de guardar
        function showSaveOptions(mode) {
            if (getEnabledFrames().length === 0) {
                showMessage("Habilita almenys una imatge per desar.", true);
                return;
            }
            sequenceSaveOptions.classList.add('hidden');
            gifSaveOptions.classList.add('hidden');
            if (mode === 'sequence') {
                sequenceSaveOptions.classList.remove('hidden');
                downloadAsZipCheckbox.dispatchEvent(new Event('change'));
            } else if (mode === 'gif') {
                gifSaveOptions.classList.remove('hidden');
            }
            saveInputArea.classList.remove('hidden');
            sequenceNameInput.focus();
        }

        function downloadURI(uri, name) {
            const link = document.createElement('a');
            link.download = name;
            link.href = uri;
            link.style.display = 'none';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        downloadAsZipCheckbox.addEventListener('change', () => {
            const isZip = downloadAsZipCheckbox.checked;
            if (isZip) {
                downloadSequenceButton.textContent = 'Confirmar i Descarregar ZIP';
                downloadNote.innerHTML = `**Nota important:** La generació del fitxer ZIP pot trigar uns segons.`;
            } else {
                downloadSequenceButton.textContent = 'Confirmar i Descarregar Imatges';
                downloadNote.innerHTML = `**Nota important:** Pot ser que se us demani permís per descàrregues múltiples.`;
            }
        });

        function hideSaveInput() {
            saveInputArea.classList.add('hidden');
            messageBox.classList.add('hidden');
        }
        
        function saveSequenceFiles() {
            const sequenceName = sequenceNameInput.value.trim();
            const downloadAsZip = downloadAsZipCheckbox.checked;
            if (!sequenceName) {
                showMessage("Si us plau, introdueix un nom vàlid.", true);
                return;
            }
            const enabledFrames = getEnabledFrames();
            if (enabledFrames.length === 0) {
                showMessage("No hi ha imatges habilitades.", true);
                hideSaveInput();
                return;
            }
            const sanitizedName = sequenceName.replace(/[^a-zA-Z0-9_\-]/g, '_');
            const filesToSave = enabledFrames.map((frame, index) => {
                const fileExtensionMatch = frame.name.match(/\.([a-zA-Z0-9]+)$/i);
                const originalExtension = fileExtensionMatch ? fileExtensionMatch[1] : 'png';
                const position = String(index + 1).padStart(3, '0');
                const newFileName = `${sanitizedName}_${position}.${originalExtension}`;
                return {
                    dataURL: frame.url,
                    fileName: newFileName,
                    mimeType: `image/${originalExtension}`
                };
            });

            if (downloadAsZip) {
                downloadSequenceButton.disabled = true;
                downloadSequenceButton.textContent = 'Generant ZIP...';
                showMessage(`Generant ZIP amb ${filesToSave.length} imatges.`, false);
                const zip = new JSZip();
                filesToSave.forEach(file => {
                    const base64Data = file.dataURL.split(',')[1];
                    zip.file(file.fileName, base64Data, { base64: true });
                });
                zip.generateAsync({type:"blob"})
                .then(function(content) {
                    const zipFileName = `${sanitizedName}_Sequencia.zip`;
                    const blobUrl = URL.createObjectURL(content);
                    downloadURI(blobUrl, zipFileName);
                    URL.revokeObjectURL(blobUrl);
                    showMessage(`Descàrrega de "${zipFileName}" finalitzada!`, false);
                    hideSaveInput();
                })
                .catch(err => {
                    console.error("Error generant ZIP:", err);
                    showMessage(`Error generant ZIP: ${err.message}`, true);
                })
                .finally(() => {
                    downloadSequenceButton.disabled = false;
                    downloadSequenceButton.textContent = 'Confirmar i Descarregar ZIP';
                });
            } else {
                let downloadCount = 0;
                const delay = 1000;
                downloadSequenceButton.disabled = true;
                showMessage(`Preparant descàrrega de ${filesToSave.length} fitxers...`, false);
                filesToSave.forEach((file, index) => {
                    setTimeout(() => {
                        downloadURI(file.dataURL, file.fileName);
                        downloadCount++;
                        if (downloadCount === filesToSave.length) {
                            showMessage(`Descàrregues finalitzades: ${downloadCount} imatges.`, false);
                            hideSaveInput();
                            downloadSequenceButton.disabled = false;
                        }
                    }, index * delay);
                });
            }
        }
        


async function saveAsGif() {
    const sequenceName = sequenceNameInput.value.trim();
    if (!sequenceName) {
        showMessage("Si us plau, introdueix un nom vàlid per al GIF.", true);
        return;
    }

    const enabledFrames = getEnabledFrames();
    if (enabledFrames.length === 0) {
        showMessage("No hi ha frames habilitats per crear el GIF.", true);
        hideSaveInput();
        return;
    }

    // Verificar que GIF està disponible
    if (typeof GIF === 'undefined') {
        showMessage("Error: La llibreria GIF.js no s'ha carregat. Recarrega la pàgina.", true);
        return;
    }

    generateGifButton.disabled = true;
    generateGifButton.textContent = 'Generant GIF...';
    showMessage(`Generant GIF amb ${enabledFrames.length} frames. Pot trigar uns segons...`, false);

    try {
        // Carregar la primera imatge
        const firstImg = new Image();
        firstImg.src = enabledFrames[0].url;
        await new Promise((resolve) => {
            firstImg.onload = resolve;
        });

        const width = firstImg.width;
        const height = firstImg.height;
        
        // Crear GIF amb workers = 0 per evitar problemes de CORS
        const gif = new GIF({
            workers: 0, // IMPORTANT: 0 workers = processa al thread principal
            quality: 10,
            width: width,
            height: height,
            repeat: gifLoopCheckbox.checked ? 0 : 1,
            background: '#ffffff',
            transparent: null
        });

        // Listener de progrés
        gif.on('progress', function(progress) {
            const percent = Math.round(progress * 100);
            generateGifButton.textContent = `Generant... ${percent}%`;
        });

        // Afegir cada frame
        for (let i = 0; i < enabledFrames.length; i++) {
            const frame = enabledFrames[i];
            const frameImg = new Image();
            frameImg.src = frame.url;
            
            await new Promise((resolve) => {
                frameImg.onload = resolve;
            });
            
            // Actualitzar missatge de progrés
            showMessage(`Processant frame ${i + 1} de ${enabledFrames.length}...`, false);
            
            gif.addFrame(frameImg, { 
                delay: animationSpeed,
                copy: true
            });
        }

        // Listener de finalització
        gif.on('finished', function(blob) {
            const sanitizedName = sequenceName.replace(/[^a-zA-Z0-9_\-]/g, '_');
            const gifFileName = `${sanitizedName}_animat.gif`;
            const blobUrl = URL.createObjectURL(blob);
            
            downloadURI(blobUrl, gifFileName);
            setTimeout(() => URL.revokeObjectURL(blobUrl), 1000);

            showMessage(`GIF "${gifFileName}" descarregat! Mida: ${(blob.size / 1024).toFixed(2)} KB`, false);
            hideSaveInput();
            
            generateGifButton.disabled = false;
            generateGifButton.textContent = 'Generar i Descarregar GIF';
        });

        // Listener d'error
        gif.on('error', function(error) {
            console.error("Error GIF:", error);
            showMessage(`Error: ${error.message || 'Error desconegut'}`, true);
            generateGifButton.disabled = false;
            generateGifButton.textContent = 'Generar i Descarregar GIF';
        });
        
        // Iniciar renderitzat
        gif.render();

    } catch (error) {
        console.error("Error preparant GIF:", error);
        showMessage(`Error: ${error.message}`, true);
        generateGifButton.disabled = false;
        generateGifButton.textContent = 'Generar i Descarregar GIF';
    }
}





        // Funcions d'animació
        function getEnabledFrames() {
            return animationData.filter(item => item.enabled);
        }
        
        function clearCurrentFrameHighlight() {
            document.querySelectorAll('.list-item').forEach(item => {
                item.classList.remove('is-current');
            });
        }
        
        function highlightCurrentFrame(currentFrameName) {
            clearCurrentFrameHighlight();
            const globalIndex = animationData.findIndex(frame => frame.name === currentFrameName);
            if (globalIndex !== -1) {
                const currentElement = document.querySelector(`.list-item[data-index='${globalIndex}']`);
                if (currentElement) {
                    currentElement.classList.add('is-current');
                }
            }
        }

        function displayFrame(indexInEnabledFrames) {
            const enabledFrames = getEnabledFrames();
            if (enabledFrames.length === 0) {
                clearCurrentFrameHighlight();
                return;
            }
            const totalFrames = enabledFrames.length;
            const actualIndex = indexInEnabledFrames;
            const currentFrame = enabledFrames[actualIndex];
            animationImage.src = currentFrame.url;
            imageFileName.textContent = `Fitxer: ${currentFrame.name} (${totalFrames} frames)`;
            imageIndex = actualIndex;
            highlightCurrentFrame(currentFrame.name);
        }

        function stopAnimation() {
            if (!animationInterval) return;
            clearInterval(animationInterval);
            animationInterval = null;
            playStopToggle.textContent = '▶️ Reproduir Seqüència';
            playStopToggle.classList.remove('bg-red-600', 'hover:bg-red-700');
            playStopToggle.classList.add('bg-green-600', 'hover:bg-green-700');
            updateManualControlState(getEnabledFrames().length > 0);
            showMessage('Animació aturada.', false);
        }

        function startAnimation() {
            clearInterval(animationInterval);
            const enabledFrames = getEnabledFrames();
            if (enabledFrames.length === 0) {
                stopAnimation();
                animationImage.classList.add('hidden');
                imageFileName.classList.add('hidden');
                initialMessage.classList.remove('hidden');
                initialMessage.textContent = "Cap imatge seleccionada.";
                clearCurrentFrameHighlight();
                return;
            }
            playStopToggle.textContent = '🔴 Aturar Animació';
            playStopToggle.classList.remove('bg-green-600', 'hover:bg-green-700');
            playStopToggle.classList.add('bg-red-600', 'hover:bg-red-700');
            updateManualControlState(false);
            initialMessage.classList.add('hidden');
            animationImage.classList.remove('hidden');
            imageFileName.classList.remove('hidden');
            const cycleImage = () => {
                if (enabledFrames.length > 0) {
                    displayFrame(imageIndex);
                    imageIndex = (imageIndex + 1) % enabledFrames.length;
                }
            };
            imageIndex = imageIndex >= enabledFrames.length ? 0 : imageIndex;
            cycleImage();
            animationInterval = setInterval(cycleImage, animationSpeed);
            showMessage(`Reproduint ${enabledFrames.length} imatges a ${animationSpeed}ms/frame.`, false);
        }
        
        function toggleAnimation() {
            if (animationInterval) {
                stopAnimation();
            } else if (getEnabledFrames().length > 0) {
                startAnimation();
            } else {
                showMessage("Carrega almenys una imatge primer.", true);
            }
        }

        function manualNavigate(direction) {
            if (animationInterval || prevButton.disabled) {
                showMessage("Atura l'animació per navegar manualment.", true);
                return;
            }
            const enabledFrames = getEnabledFrames();
            if (enabledFrames.length === 0) return;
            const totalFrames = enabledFrames.length;
            let nextIndex = imageIndex + direction;
            if (nextIndex < 0) {
                nextIndex = totalFrames - 1;
            } else if (nextIndex >= totalFrames) {
                nextIndex = 0;
            }
            displayFrame(nextIndex);
        }

        // Event Listeners
        speedSlider.addEventListener('input', (e) => {
            animationSpeed = parseInt(e.target.value, 10);
            speedValue.textContent = `${animationSpeed} ms`;
            if (animationInterval) {
                startAnimation();
            }
        });

        bgColorPicker.addEventListener('input', (e) => {
            animationArea.classList.remove('bg-gray-100');
            animationArea.style.backgroundColor = e.target.value;
        });
        
        function toggleAllFrames(enable) {
            animationData.forEach(item => {
                item.enabled = enable;
            });
            renderImageList();
            if (enable) {
                if (animationData.length > 0) {
                    imageIndex = 0;
                    displayFrame(0);
                    updateManualControlState(true);
                    stopAnimation();
                }
            } else {
                stopAnimation();
                animationImage.classList.add('hidden');
                imageFileName.classList.add('hidden');
                initialMessage.classList.remove('hidden');
                initialMessage.textContent = "Cap imatge seleccionada.";
                updateManualControlState(false);
                clearCurrentFrameHighlight();
            }
        }

        // Funcions Drag and Drop
        function dragStart(e) {
            if (this.classList.contains('disabled')) {
                e.preventDefault();
                return;
            }
            dragSrcEl = this;
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', this.dataset.index);
            this.classList.add('dragging');
        }

        function dragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            return false;
        }

        function dragEnter(e) {
            if (dragSrcEl !== this && !this.classList.contains('disabled')) {
                this.classList.add('bg-indigo-100');
            }
        }

        function dragLeave(e) {
            this.classList.remove('bg-indigo-100');
        }

        function handleDrop(e) {
            e.stopPropagation();
            this.classList.remove('bg-indigo-100');
            if (dragSrcEl !== this) {
                const targetIndex = parseInt(this.dataset.index, 10);
                const sourceIndex = parseInt(dragSrcEl.dataset.index, 10);
                const [movedItem] = animationData.splice(sourceIndex, 1);
                animationData.splice(targetIndex, 0, movedItem);
                renderImageList();
                if (animationInterval) {
                    startAnimation();
                } else {
                    const enabledFrames = getEnabledFrames();
                    if (enabledFrames.length > 0) {
                        imageIndex = Math.min(imageIndex, enabledFrames.length - 1);
                        displayFrame(imageIndex);
                        updateManualControlState(true);
                    } else {
                        stopAnimation();
                    }
                }
            }
            return false;
        }

        function dragEnd(e) {
            this.classList.remove('dragging');
            document.querySelectorAll('#imageList li').forEach(item => {
                item.classList.remove('bg-indigo-100');
            });
        }
        
        function handleCheckboxChange(index, checkbox) {
            animationData[index].enabled = checkbox.checked;
            const listItem = checkbox.closest('.list-item');
            if (checkbox.checked) {
                listItem.classList.remove('disabled');
                listItem.draggable = true;
            } else {
                listItem.classList.add('disabled');
                listItem.draggable = false;
            }
            if (animationInterval) {
                startAnimation();
            } else {
                const enabledFrames = getEnabledFrames();
                if (enabledFrames.length > 0) {
                    const newIndex = Math.min(imageIndex, enabledFrames.length > 0 ? enabledFrames.length - 1 : 0);
                    imageIndex = newIndex;
                    if (enabledFrames.length > 0) {
                        displayFrame(imageIndex);
                        updateManualControlState(true);
                    } else {
                        stopAnimation();
                        animationImage.classList.add('hidden');
                        imageFileName.classList.add('hidden');
                        initialMessage.classList.remove('hidden');
                        initialMessage.textContent = "Cap imatge seleccionada.";
                        clearCurrentFrameHighlight();
                    }
                } else {
                    stopAnimation();
                }
            }
        }

        // Renderització de la llista
        function renderImageList() {
            imageList.innerHTML = '';
            animationData.forEach((data, index) => {
                const li = document.createElement('li');
                li.className = `list-item ${data.enabled ? '' : 'disabled'}`;
                li.draggable = data.enabled;
                li.dataset.index = index;
                li.innerHTML = `
                    <div class="flex items-center gap-2 w-full">
                        <input type="checkbox" id="img-${index}" class="frame-checkbox form-checkbox h-4 w-4 text-indigo-600 rounded" 
                               ${data.enabled ? 'checked' : ''} data-index="${index}">
                        <label for="img-${index}" class="flex items-center flex-1 min-w-0">
                            <img src="${data.url}" alt="Frame ${index + 1}" class="thumbnail">
                            <span class="font-bold text-indigo-600 w-6 text-center shrink-0">${index + 1}.</span>
                            <span class="flex-1 text-gray-800 truncate px-2 frame-name">${data.name}</span>
                        </label>
                    </div>
                    <span class="text-gray-400 drag-handle shrink-0 ml-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                          <path d="M5 4a1 1 0 011-1h8a1 1 0 011 1v4h-2V6H7v2H5V4zm0 8v4h2v-2h6v2h2v-4H5zm4-4h2v2H9V8z"/>
                        </svg>
                    </span>
                `;
                const checkbox = li.querySelector('.frame-checkbox');
                checkbox.addEventListener('change', function() {
                    handleCheckboxChange(index, this);
                });
                li.querySelector('label').addEventListener('click', (e) => {
                    if (animationInterval) {
                        e.preventDefault();
                        return;
                    }
                    if (!data.enabled) {
                        e.preventDefault();
                        return;
                    }
                    const enabledFrames = getEnabledFrames();
                    const enabledIndex = enabledFrames.findIndex(f => f.name === data.name);
                    if (enabledIndex !== -1) {
                        displayFrame(enabledIndex);
                    }
                });
                li.addEventListener('dragstart', dragStart);
                li.addEventListener('dragenter', dragEnter);
                li.addEventListener('dragover', dragOver);
                li.addEventListener('dragleave', dragLeave);
                li.addEventListener('drop', handleDrop);
                li.addEventListener('dragend', dragEnd);
                imageList.appendChild(li);
            });
            if (getEnabledFrames().length > 0) {
                displayFrame(imageIndex);
            } else {
                clearCurrentFrameHighlight();
            }
            updateMassSelectButtons();
        }

        // Càrrega d'imatges
        function handleUpload(event) {
            event.preventDefault();
            const files = fileInput.files;
            if (files.length < 1) {
                showMessage("Selecciona almenys 1 imatge.", true);
                updateManualControlState(false);
                return;
            }
            stopAnimation();
            animationData = [];
            showMessage(`Processant ${files.length} imatges...`, false);
            const fileArray = Array.from(files);
            fileArray.sort((a, b) => a.name.localeCompare(b.name));
            let filesProcessed = 0;
            fileArray.forEach(file => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    animationData.push({
                        url: e.target.result,
                        name: file.name,
                        enabled: true
                    });
                    filesProcessed++;
                    if (filesProcessed === fileArray.length) {
                        finalizeLoad();
                        uploadDialog.close();
                    }
                };
                reader.onerror = () => {
                    console.error("Error llegint:", file.name);
                    filesProcessed++;
                    if (filesProcessed === fileArray.length) {
                        finalizeLoad();
                        uploadDialog.close();
                    }
                };
                reader.readAsDataURL(file);
            });
        }
        
        // Càrrega de vídeo
        async function handleVideoUpload(event) {
            event.preventDefault();
            const file = videoInput.files[0];
            const fps = parseInt(frameRateInput.value, 10);
            if (!file) {
                showMessage("Selecciona un vídeo.", true, videoMessageBox);
                return;
            }
            if (isNaN(fps) || fps < 1 || fps > 30) {
                showMessage("FPS entre 1 i 30.", true, videoMessageBox);
                return;
            }
            const trimStart = parseFloat(trimStartInput.value);
            let trimEnd = parseFloat(trimEndInput.value);
            if (isNaN(trimStart) || trimStart < 0) {
                showMessage("Inici >= 0.", true, videoMessageBox);
                return;
            }
            if (isNaN(trimEnd) || trimEnd < 0) {
                showMessage("Final >= 0.", true, videoMessageBox);
                return;
            }
            stopAnimation();
            animationData = [];
            setProcessingState(true, "Carregant vídeo...");
            let videoURL = null;
            try {
                const videoElement = document.createElement('video');
                videoElement.preload = 'metadata';
                videoElement.muted = true;
                videoElement.style.display = 'none';
                videoURL = URL.createObjectURL(file);
                videoElement.src = videoURL;
                await new Promise((resolve, reject) => {
                    videoElement.onloadedmetadata = resolve;
                    videoElement.onerror = (e) => {
                        reject(new Error(`Error carregant vídeo: ${e.target.error.code}`));
                    };
                });
                const fullDuration = videoElement.duration;
                if (trimStart >= fullDuration) {
                    throw new Error(`Inici (${trimStart.toFixed(2)}s) > durada (${fullDuration.toFixed(2)}s).`);
                }
                if (trimEnd === 0 || trimEnd > fullDuration) {
                    trimEnd = fullDuration;
                }
                if (trimStart >= trimEnd) {
                    throw new Error("Inici < Final.");
                }
                const durationToExtract = trimEnd - trimStart;
                const interval = 1 / fps;
                const totalFrames = Math.floor(durationToExtract / interval);
                if (totalFrames === 0) {
                    throw new Error("Trim/FPS genera 0 frames.");
                }
                setProcessingState(true, `Extreient ${totalFrames} frames...`);
                const canvas = document.createElement('canvas');
                canvas.width = videoElement.videoWidth;
                canvas.height = videoElement.videoHeight;
                const ctx = canvas.getContext('2d');
                const seekAndDraw = (time, frameCount) => {
                    return new Promise((resolve) => {
                        let seekTimeout;
                        const handleSeeked = () => {
                            clearTimeout(seekTimeout);
                            videoElement.removeEventListener('seeked', handleSeeked);
                            videoElement.removeEventListener('error', handleError);
                            ctx.drawImage(videoElement, 0, 0, canvas.width, canvas.height);
                            const dataURL = canvas.toDataURL('image/png');
                            resolve(dataURL);
                        };
                        const handleError = () => {
                            clearTimeout(seekTimeout);
                            videoElement.removeEventListener('seeked', handleSeeked);
                            videoElement.removeEventListener('error', handleError);
                            console.error(`Error buscant al temps ${time}s (frame ${frameCount}).`);
                            resolve(null);
                        };
                        seekTimeout = setTimeout(() => {
                            handleError();
                            console.warn(`Timeout buscant el frame al temps ${time}s.`);
                        }, 5000);
                        videoElement.addEventListener('seeked', handleSeeked);
                        videoElement.addEventListener('error', handleError);
                        videoElement.currentTime = time;
                    });
                };
                for (let i = 0; i < totalFrames; i++) {
                    const currentTime = trimStart + (i * interval);
                    const frameNumber = i + 1;
                    if (currentTime >= trimEnd + 0.001) break;
                    const dataURL = await seekAndDraw(currentTime, i);
                    if (dataURL) {
                        animationData.push({
                            url: dataURL,
                            name: `${file.name.split('.')[0]}_trim_${trimStart.toFixed(1)}s_frame_${String(frameNumber).padStart(4, '0')}.png`,
                            enabled: true
                        });
                        setProcessingState(true, `Extret frame ${frameNumber} de ${totalFrames}. (${(currentTime-trimStart).toFixed(2)}s)`);
                    }
                }
                videoDialog.close();
                finalizeLoad();
            } catch (error) {
                console.error("Error durant el processament del vídeo:", error);
                showMessage(`Error durant el processament del vídeo: ${error.message}.`, true, videoMessageBox);
            } finally {
                if (videoURL) URL.revokeObjectURL(videoURL);
                setProcessingState(false);
            }
        }
        
        // Finalització de càrrega
        function finalizeLoad() {
            if (animationData.length === 0) {
                showMessage("Cap imatge carregada amb èxit.", true);
                return;
            }
            imageIndex = 0;
            renderImageList();
            mainGrid.classList.remove('hidden');
            if (animationData.length <= 1) {
                displayFrame(0);
                animationImage.classList.remove('hidden');
                imageFileName.classList.remove('hidden');
                initialMessage.classList.add('hidden');
                updateManualControlState(true);
                showMessage(`Imatge carregada (${animationData[0].name}).`, false);
                playStopToggle.textContent = '▶️ Reproduir Seqüència';
                playStopToggle.classList.remove('bg-red-600', 'hover:bg-red-700');
                playStopToggle.classList.add('bg-green-600', 'hover:bg-green-700');
            } else {
                startAnimation();
            }
            updateMassSelectButtons();
            showMessage(`Procés de càrrega finalitzat. ${animationData.length} imatges extretes i preparades.`, false);
        }


// IMPORTANT: Afegeix aquesta verificació al final del <script>, just abans del tancament:
// Verificar que gif.js s'ha carregat correctament
window.addEventListener('load', function() {
    console.log('Verificant càrrega de llibreries...');
    console.log('gifshot carregat:', typeof gifshot !== 'undefined');
    console.log('JSZip carregat:', typeof JSZip !== 'undefined');
    
    if (typeof gifshot === 'undefined') {
        console.error('ATENCIÓ: gifshot no s\'ha carregat correctament!');
        alert('Error carregant gifshot. Comprova la connexió a Internet i recarrega la pàgina.');
    }
    
    // Inicialització de l'aplicació
    updateManualControlState(false);
    updateMassSelectButtons();
    playStopToggle.textContent = '▶️ Reproduir Seqüència';
    playStopToggle.classList.remove('bg-red-600', 'hover:bg-red-700');
    playStopToggle.classList.add('bg-green-600', 'hover:bg-green-700');
    downloadAsZipCheckbox.checked = false;
    downloadAsZipCheckbox.dispatchEvent(new Event('change'));
    sequenceSaveOptions.classList.add('hidden');
    gifSaveOptions.classList.add('hidden');
});
    </script>
</body>
</html>
